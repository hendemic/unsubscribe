# Password is stored in your OS keychain (unsubscribe)
# To use a command instead, add:
#   password_command = "pass show email/imap"

[imap]
# Provider type: "imap" (default) or "gmail"
# Gmail uses OAuth and the Gmail REST API instead of IMAP.
provider = "imap"
host = "imap.sample.com"
port = 993
username = "you@sample.com"
auth_type = "password"
# password_command = "pass show email/zoho"
# password = "fallback-plaintext-password"  # not recommended
# SMTP settings for mailto unsubscribe (used with --mailto flag)
# If omitted, derived from IMAP host (imap.X -> smtp.X, port 465)
# smtp_host = "smtp.sample.com"
# smtp_port = 465

[scan]
# Folders to scan for unsubscribe links
folders = ["INBOX"]
# Folder to move archived emails into
archive_folder = "Unsubscribed"

# Common IMAP hosts:
#   Gmail:      imap.gmail.com (or use provider = "gmail" for OAuth)
#   Outlook:    outlook.office365.com
#   Yahoo:      imap.mail.yahoo.com
#   Zoho:       imap.zoho.com
#   iCloud:     imap.mail.me.com (app-specific password required)
#   Fastmail:   imap.fastmail.com
#
# Folder names vary by provider:
#   Gmail:   folders use "[Gmail]/" prefix, e.g. "[Gmail]/All Mail", "[Gmail]/Promotions"
#   Outlook: "Inbox", "Junk Email", etc.
#   Most others: "INBOX", "Sent", etc.

# --- Gmail OAuth example ---
# [imap]
# provider = "gmail"
# host = "gmail.googleapis.com"
# port = 443
# username = "you@gmail.com"
# auth_type = "oauth"
#
# [scan]
# folders = ["INBOX"]
# archive_folder = "Unsubscribed"
