# Password is stored in your OS keychain (unsubscribe)
# To use a command instead, add:
#   password_command = "pass show email/imap"

[imap]
host = "imap.sample.com"
port = 993
username = "you@sample.com"
# password_command = "pass show email/zoho"
# password = "fallback-plaintext-password"  # not recommended

[scan]
# Folders to scan for unsubscribe links
folders = ["INBOX"]
# Folder to move archived emails into
archive_folder = "Unsubscribed"
